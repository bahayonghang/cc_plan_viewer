{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plan Viewer",
  "version": "1.2.0",
  "identifier": "com.plan-viewer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Plan Viewer",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon-32x32.png",
      "icons/icon-128x128.png",
      "icons/icon-256x256.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "View and review Claude Code plans",
    "longDescription": "A desktop application for viewing, annotating, and commenting on Claude Code architecture plans with live Mermaid diagram rendering."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
